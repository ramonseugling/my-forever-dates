# Environment Variables

# ─── Database ─────────────────────────────────────────────────────────────────
# Local (Docker): postgres://local_user:local_password@localhost:5432/my_forever_dates
# Production (Neon): postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional: custom CA certificate for SSL (only needed if your provider requires it)
# POSTGRES_CA=

# ─── Migrations ───────────────────────────────────────────────────────────────
# Secret token to authorize POST /api/v1/migrations
# Generate with: openssl rand -hex 32
MIGRATIONS_TOKEN=

# ─── SMTP (email notifications) ───────────────────────────────────────────────
# Local: use MailCatcher (SMTP_HOST=localhost, SMTP_PORT=1025)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
